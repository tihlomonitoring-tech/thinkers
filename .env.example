# Azure SQL Database – use either a full connection string or individual vars

# Option 1: Full connection string (overrides individual vars)
# AZURE_SQL_CONNECTION_STRING=Server=YOUR_SERVER.database.windows.net,1433;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=true;TrustServerCertificate=false

# Option 2: Individual values
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=
AZURE_SQL_PORT=

# Frontend URL – required in production for password-reset and other email links (no trailing slash)
# FRONTEND_ORIGIN=https://your-app.netlify.app
# APP_URL=https://your-app.netlify.app

# Email – optional; if not set, sendEmail no-ops until you add alerts
# Gmail: EMAIL_HOST=smtp.gmail.com (default), EMAIL_USER=your@gmail.com, EMAIL_PASS=App Password from https://myaccount.google.com/apppasswords
# Outlook / Microsoft 365 (work): set the three below. Use full work email and password (or App Password if MFA required).
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=Thinkers
# Optional – defaults shown (only set for Outlook/Microsoft 365)
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
