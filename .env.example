# Azure SQL Database – use either a full connection string or individual vars

# Option 1: Full connection string (overrides individual vars)
# AZURE_SQL_CONNECTION_STRING=Server=YOUR_SERVER.database.windows.net,1433;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=true;TrustServerCertificate=false

# Option 2: Individual values
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=
AZURE_SQL_PORT=

# Frontend URL – required in production for password-reset and other email links (no trailing slash)
# FRONTEND_ORIGIN=https://your-app.netlify.app
# APP_URL=https://your-app.netlify.app

# Email – optional; if not set, sendEmail no-ops until you add alerts
#
# Gmail:
#   EMAIL_USER=your@gmail.com
#   EMAIL_PASS=<App Password – NOT your normal password>
#   Create App Password: https://myaccount.google.com/apppasswords (requires 2FA to be on)
#
# Outlook / Microsoft 365:
#   EMAIL_HOST=smtp.office365.com
#   EMAIL_PORT=587
#   EMAIL_SECURE=false
#   EMAIL_USER=your@company.com
#   EMAIL_PASS=your password or App Password if MFA is on (https://account.microsoft.com/security)
#
# If you see "SMTP authentication failed":
#   • Gmail: Turn on 2FA, then create an App Password and set EMAIL_PASS to that 16-letter password.
#   • Outlook/M365: Enable "Authenticated SMTP" for the mailbox in admin, or use an App Password.
#   • No spaces or quotes around values in .env. Restart the server after changing .env.
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=Thinkers
# Optional – only set for non-Gmail (defaults: smtp.gmail.com, 587, secure=false)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
