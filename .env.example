# Azure SQL / SQL Server — use a full connection string or individual vars below.
#
# Production (Azure Web App, ECS, Railway, etc.): .env is gitignored and NOT deployed.
# Copy the same variable names and values into your host:
#   Azure: App Service → Settings → Configuration → Application settings → New application setting
#   Docker/ECS: task definition environment or Secrets Manager JSON keys matching SQLSERVER_*

# Option 1: Full connection string (overrides individual vars)
# AZURE_SQL_CONNECTION_STRING=Server=YOUR_SERVER.database.windows.net,1433;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=true;TrustServerCertificate=false

# Option 2: Individual values
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=
AZURE_SQL_PORT=

# SQL Server on AWS (RDS) — use SQLSERVER_* (not AWS_*; many AWS hosts forbid env vars starting with AWS_)
# SQLSERVER_CONNECTION_STRING=Server=YOUR_RDS_ENDPOINT,1433;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=true;TrustServerCertificate=false
SQLSERVER_HOST=
SQLSERVER_DATABASE=
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_PORT=

# RDS + Node TLS: set true if you see "unable to get local issuer certificate" without RDS CA bundle
# SQLSERVER_TRUST_SERVER_CERTIFICATE=true

# Legacy (still supported): AWS_SQL_* / AZURE_SQL_*

# Frontend URL – required in production for password-reset, CORS, and other email links (no trailing slash)
# FRONTEND_ORIGIN=https://your-app.netlify.app
# APP_URL=https://your-app.netlify.app
#
# CORS: if users open the app at more than one hostname (e.g. www + apex + Azure default URL), add the rest here:
# FRONTEND_ORIGINS=https://wiseapp.co.za,https://your-app.azurewebsites.net

# Email – required for password reset, notifications, etc.
# Leave EMAIL_USER + EMAIL_PASS empty to disable sending (isEmailConfigured() = false).
# Set both to enable. Restart the API after changes.
#
# EMAIL_ENABLED=true
#   Omit or set true: email on when USER+PASS set. Set false | 0 | no to force all sends off.
#
# EMAIL_SKIP_SMTP_VERIFY=true
#   If verify() fails but you believe credentials are correct (common with some Office365 setups),
#   set this to skip preflight verify and send anyway.
#
# Gmail:
#   EMAIL_USER=your@gmail.com
#   EMAIL_PASS=<App Password – NOT your normal password>
#   Create App Password: https://myaccount.google.com/apppasswords (requires 2FA to be on)
#
# Outlook / Microsoft 365:
#   EMAIL_HOST=smtp.office365.com
#   EMAIL_PORT=587
#   EMAIL_SECURE=false
#   EMAIL_USER=your@company.com
#   EMAIL_PASS=your password or App Password if MFA is on (https://account.microsoft.com/security)
#   In M365 admin: enable "Authenticated SMTP" for the mailbox if you get 535.7.139.
#
# Amazon SES (SMTP interface):
#   EMAIL_HOST=email-smtp.af-south-1.amazonaws.com
#   EMAIL_PORT=587
#   EMAIL_SECURE=false
#   EMAIL_USER=<SMTP username from SES SMTP credentials>
#   EMAIL_PASS=<SMTP password from SES SMTP credentials>
#   (Verify domain/addresses in SES; production may need leaving sandbox.)
#
# Password-reset links need your real app URL:
#   FRONTEND_ORIGIN=https://your-domain.com
#
# If you see "SMTP authentication failed":
#   • Gmail: App Password + 2FA.
#   • Outlook/M365: Authenticated SMTP + correct password.
#   • No spaces or quotes around values in .env.
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=Thinkers
# Optional – only set for non-Gmail (defaults: smtp.gmail.com, 587, secure=false)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
